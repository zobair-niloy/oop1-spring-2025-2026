interface IMemberOperation {
    double discountedFee();
}


abstract class Member {
    String memberID;
    double monthlyFee;

    Member() {}

    Member(String memberID, double monthlyFee) {
        this.memberID = memberID;
        this.monthlyFee = monthlyFee;
    }

    abstract void showInfo();
}


class PlatinumMember extends Member implements IMemberOperation {
    int freeSessions;

    PlatinumMember() {}

    PlatinumMember(String memberID, double monthlyFee, int freeSessions) {
        super(memberID, monthlyFee);
        this.freeSessions = freeSessions;
    }

    @Override
    public double discountedFee() {
        if (monthlyFee > 8000) {
            return monthlyFee - (monthlyFee * 0.08);
        }
        return monthlyFee;
    }

    @Override
    void showInfo() {
        System.out.println("Platinum Member ID: " + memberID);
        System.out.println("Monthly Fee: " + monthlyFee);
        System.out.println("Free Sessions: " + freeSessions);
        System.out.println("Discounted Fee: " + discountedFee());
    }
}


class StandardMember extends Member implements IMemberOperation {
    boolean groupClassAccess;

    StandardMember() {}

    StandardMember(String memberID, double monthlyFee, boolean groupClassAccess) {
        super(memberID, monthlyFee);
        this.groupClassAccess = groupClassAccess;
    }

    @Override
    public double discountedFee() {
        if (monthlyFee > 8000) {
            return monthlyFee - (monthlyFee * 0.08);
        }
        return monthlyFee;
    }

    @Override
    void showInfo() {
        System.out.println("Standard Member ID: " + memberID);
        System.out.println("Monthly Fee: " + monthlyFee);
        System.out.println("Group Class Access: " + groupClassAccess);
        System.out.println("Discounted Fee: " + discountedFee());
    }
}


class Gym {
    String name;
    Member mm[];

    Gym() {}

    Gym(String name, int count) {
        this.name = name;
        this.mm = new Member[count];
    }

    void addMember(Member m) {
        for (int i = 0; i < mm.length; i++) {
            if (mm[i] == null) {
                mm[i] = m;
                System.out.println("Member added: " + m.memberID);
                return;
            }
        }
        System.out.println("Gym is full.");
    }

    void removeMember(String memberID) {
        for (int i = 0; i < mm.length; i++) {
            if (mm[i] != null && mm[i].memberID.equals(memberID)) {
                mm[i] = null;
                System.out.println("Member removed: " + memberID);
                return;
            }
        }
        System.out.println("Member not found.");
    }

    void showMembers() {
        System.out.println("Gym Name: " + name);
        for (Member m : mm) {
            if (m != null) {
                m.showInfo();
                System.out.println("--------------------");
            }
        }
    }

    void totalRevenue() {
        double total = 0;
        for (Member m : mm) {
            if (m != null) {
                
                if (m instanceof IMemberOperation) {
                    total += ((IMemberOperation) m).discountedFee();
                } else {
                    total += m.monthlyFee;
                }
            }
        }
        System.out.println("Total Revenue: " + total);
    }
}


public class Start {
    public static void main(String[] args) {
        
        Member m1 = new PlatinumMember("P001", 9000.0, 5);
        Member m2 = new StandardMember("S001", 7000.0, true);

       
        Gym gym = new Gym("FitZone", 5);

        gym.addMember(m1);
        gym.addMember(m2);

        System.out.println("\n--- All Members ---");
        gym.showMembers();

        gym.totalRevenue();

        System.out.println("\n--- Removing Member ---");
        gym.removeMember("S001");
        gym.showMembers();
    }
}